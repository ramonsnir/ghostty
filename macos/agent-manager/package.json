{
  "name": "ghostty-agent-manager",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Phase-1 status summarizer for the Ghostty Agent Manager sidecar.",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run bundle",
    "bundle": "node esbuild.config.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "tsc -p tsconfig.json && node --test \"dist/**/*.test.js\""
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.185"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.6.0"
  }
}
